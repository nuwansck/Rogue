{
  "bot_name": "Rogue v1.2",
  "demo_mode": true,
  "trade_gold": true,
  "signal_threshold": 4,
  "position_full_usd": 100,
  "position_partial_usd": 66,

  "_comment_sl_tp": "v4.0: ATR-based SL. TP = SL x rr_ratio. Do not use pct_based — SL too tight for gold volatility.",
  "sl_mode": "atr_based",
  "tp_mode": "rr_multiple",
  "atr_sl_multiplier": 1.0,
  "sl_min_usd": 15.0,
  "sl_max_usd": 40.0,
  "rr_ratio": 2.0,
  "sl_pct": 0.0025,
  "fixed_sl_usd": 20.0,
  "fixed_tp_usd": null,

  "_comment_breakeven": "v4.0: re-enabled. Fires at ~65% toward TP with ATR SL.",
  "breakeven_trigger_usd": 15.0,

  "margin_safety_factor": 0.75,
  "margin_retry_safety_factor": 0.4,
  "auto_scale_on_margin_reject": true,
  "xau_margin_rate_override": 0.05,
  "telegram_show_margin": true,

  "max_concurrent_trades": 1,
  "pyramid_enabled": false,
  "pyramid_min_score": 5,
  "pyramid_sl_usd": 1.5,
  "pyramid_max_risk_usd": 50,

  "max_trades_day": 8,
  "max_losing_trades_day": 3,
  "max_losing_trades_session": 2,
  "loss_streak_cooldown_min": 30,

  "_comment_exhaustion": "v4.0: S2/R2 Extended setups are hard-blocked (not just penalised) when stretch exceeds this.",
  "exhaustion_atr_mult": 2.0,

  "max_spread_pips": 150,
  "spread_limits": {
    "London": 130,
    "US": 130
  },

  "session_only": true,
  "session_thresholds": {
    "London": 3,
    "US": 3
  },
  "max_trades_london": 4,
  "max_trades_us": 4,
  "session_start_hour_sgt": 16,
  "session_end_hour_sgt": 1,
  "trading_day_start_hour_sgt": 8,

  "news_filter_enabled": true,
  "news_block_before_min": 30,
  "news_block_after_min": 30,
  "news_lookahead_min": 120,
  "news_medium_penalty_score": -1,

  "friday_cutoff_hour_sgt": 23,
  "friday_cutoff_minute_sgt": 0,

  "same_setup_cooldown_min": 15,

  "account_balance_override": 0,
  "cycle_minutes": 5,
  "db_retention_days": 90,
  "db_cleanup_hour_sgt": 0,
  "db_cleanup_minute_sgt": 15,
  "db_vacuum_weekly": true,

  "_comment_daily_report": "v1.1: wired-up daily Telegram report time (was hardcoded 15:30 in v1.0).",
  "daily_report_hour_sgt": 8,
  "daily_report_minute_sgt": 0,

  "calendar_fetch_interval_min": 60,
  "calendar_retry_after_min": 15,
  "midnight_guard_min": 0,
  "tp_pct": 0.0075
}
